def print_rangoli(size):
    alpha="abcdefghijklmnopqrstuvwxyz"
    
    lines = []
    for i in range (size):
        left=alpha[size-1:i:-1]
        right=alpha[i:size]
        row='-'.join(left+right)
        lines.append(row.center(4*size-3,"-"))
         
    for line in lines[::-1]:
        print(line)
        
    for line in lines[1:]:
        print(line)
        
if __name__ == '__main__':
    n = int(input())
    print_rangoli(n)
